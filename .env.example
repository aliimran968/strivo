# Supabase — copy from your project's API settings (Settings → API)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Seed script only (scripts/seed-user.js) — not needed for running the app
SEED_EMAIL=test@example.com
SEED_PASSWORD=changeme
SEED_NAME=Your Name
